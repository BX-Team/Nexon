# Nexon local dev config. Copy to `.env` (gitignored) and fill in.
# The binary auto-loads `.env` from the working directory; real environment
# variables always take precedence over this file.

# --- Subscription links ---
# For local UX testing localhost is fine; for a client to actually fetch the
# config you need a public URL (domain, or a tunnel like cloudflared/ngrok).
NEXON_SUB_BASE_URL=http://localhost:8080

# --- Storage / listener (sane local defaults) ---
NEXON_DB=./nexon-dev.db
NEXON_SUB_LISTEN=:8080

# --- Dev helpers ---
# No real Xray node? Use the logging connector so syncs don't try to dial.
NEXON_NODE_MODE=stub
